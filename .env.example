POSTGRES_DB=healthora
POSTGRES_USER=healthora_user
POSTGRES_PASSWORD=healthora_password
POSTGRES_HOST_PORT=5433

DATABASE_URL=postgresql+psycopg2://healthora_user:healthora_password@postgres:5432/healthora
VITE_API_BASE_URL=http://localhost:8000
JWT_SECRET_KEY=healthora-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
SYSADMIN_BOOTSTRAP_KEY=
ENABLE_STARTUP_SEED=false
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?
HIS_PATIENT_SEED_LIMIT=300
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AI_QUERY_MAX_ROWS=500
AI_RESPONSE_MAX_ROWS=200
AI_SQL_TIMEOUT_MS=5000
AI_RAG_THRESHOLD=0.84
AI_SCHEMA_FAMILY=legacy
AI_LINKER_TOP_K=10
AI_JOIN_PATH_CUTOFF=6
AI_MAX_PATH_CANDIDATES=5
AI_STEINER_MIN_TERMINALS=3
AI_PLAN_CACHE_SIZE=300
AI_HINT_CACHE_TTL_SECONDS=900
AI_PATH_SEMANTIC_WEIGHT=0.76
AI_PATH_LENGTH_WEIGHT=0.10
AI_PATH_NULLABLE_WEIGHT=0.10
